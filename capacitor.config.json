{
  "appId": "com.pjt222.gateway",
  "appName": "Gateway Session",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#000004",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#000004"
    },
    "Keyboard": {
      "resize": "none",
      "style": "DARK"
    }
  }
}
